# Larangan akses langsung ke direktori (hapus "Index of")
Options -Indexes

# Set file default yang dibuka saat akses folder
DirectoryIndex index.php

# Redirect semua akses ke folder root langsung ke index.php
RewriteEngine On
RewriteBase /admin_updated/

# Jika mengakses root folder tanpa file, arahkan ke index.php
RewriteRule ^$ index.php [L]
